rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && (
          request.auth.token.admin == true
          || request.auth.token.email in get(/databases/$(database)/documents/appConfig/admins).data.adminEmails
        );
    }

    function approvedMusicSubmission(submissionId) {
      return signedIn()
        && submissionId is string
        && get(/databases/$(database)/documents/musicSubmissions/$(submissionId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/musicSubmissions/$(submissionId)).data.status == "approved"
        && request.resource.data.audioUrl == get(/databases/$(database)/documents/musicSubmissions/$(submissionId)).data.audioUrl;
    }

    function onlyFollowerCountChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["followersCount", "updatedAt"]);
    }

    function onlyLikeCountChanged() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["likesCount"])
        && request.resource.data.likesCount is int
        && request.resource.data.likesCount >= 0
        && (
          request.resource.data.likesCount == resource.data.likesCount + 1
          || request.resource.data.likesCount == resource.data.likesCount - 1
        );
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if owns(userId);
      allow update: if owns(userId) || isAdmin() || onlyFollowerCountChanged();
      allow delete: if isAdmin();

      match /followers/{followerId} {
        allow read: if true;
        allow create: if signedIn()
          && request.auth.uid == followerId
          && request.resource.data.followerId == request.auth.uid
          && request.resource.data.followingId == userId
          && request.auth.uid != userId;
        allow delete: if signedIn() && request.auth.uid == followerId;
        allow update: if false;
      }

      match /following/{followingId} {
        allow read: if owns(userId) || isAdmin();
        allow create: if signedIn()
          && request.auth.uid == userId
          && request.resource.data.followerId == request.auth.uid
          && request.resource.data.followingId == followingId
          && request.auth.uid != followingId;
        allow delete: if signedIn() && request.auth.uid == userId;
        allow update: if false;
      }
    }

    match /albums/{albumId} {
      allow read: if resource.data.status in ["published", "scheduled"] || owns(resource.data.userId) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if owns(resource.data.userId) || isAdmin() || onlyLikeCountChanged();
      allow delete: if isAdmin();
    }

    match /tracks/{trackId} {
      allow read: if resource.data.status == "published" || owns(resource.data.userId) || isAdmin();
      allow create: if isAdmin()
        || (
          signedIn()
          && request.resource.data.userId == request.auth.uid
          && approvedMusicSubmission(request.resource.data.sourceSubmissionId)
        );
      allow update: if owns(resource.data.userId) || isAdmin() || onlyLikeCountChanged();
      allow delete: if isAdmin();
    }

    match /musicSubmissions/{submissionId} {
      allow read: if owns(resource.data.userId) || isAdmin();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.mimeType == "audio/mpeg"
        && request.resource.data.fileExtension == "mp3";
      allow update: if isAdmin()
        || (
          owns(resource.data.userId)
          && request.resource.data.userId == resource.data.userId
          && (
            (
              resource.data.status in ["uploaded", "fingerprint_queued"]
              && request.resource.data.status == "fingerprint_queued"
            )
            || (
              resource.data.status == "approved"
              && request.resource.data.status == "completed"
              && request.resource.data.completedTrackId is string
            )
          )
        );
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if resource.data.status == "published" || owns(resource.data.userId) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if owns(resource.data.userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if owns(resource.data.userId) || isAdmin();
    }

    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if owns(resource.data.userId) || isAdmin();
      allow update: if false;
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /playlists/{playlistId} {
      allow read: if resource.data.isPublic == true || owns(resource.data.userId) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if owns(resource.data.userId) || isAdmin();
    }

    match /collections/{collectionId} {
      allow read: if resource.data.isPublic == true || owns(resource.data.userId) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if owns(resource.data.userId) || isAdmin();
    }

    match /recentPlays/{playId} {
      allow read: if owns(resource.data.userId);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update: if owns(resource.data.userId);
      allow create, delete: if isAdmin();
    }

    match /releaseReminders/{reminderId} {
      allow read: if owns(resource.data.userId) || isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if owns(resource.data.userId) || isAdmin();
      allow update: if false;
    }

    match /messageThreads/{threadId} {
      allow read, update: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participantIds;
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn() && request.resource.data.reporterId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /adminDeletionRequests/{requestId} {
      allow create: if isAdmin()
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.targetUid is string
        && (
          request.resource.data.targetUid != request.auth.uid
          || request.resource.data.selfDelete == true
        );
      allow read, update, delete: if isAdmin();
    }

    match /profileRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if owns(resource.data.userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /verificationRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if owns(resource.data.userId) || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /appConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
